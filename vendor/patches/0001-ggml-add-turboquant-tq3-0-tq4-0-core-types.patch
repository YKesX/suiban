Subject: [PATCH 1/4] ggml: add TurboQuant TQ3_0 / TQ4_0 core types (CPU reference)

Target: PrismML-Eng/llama.cpp tag prism-b9596-9fcaed7.

New GGML types for KV-cache quantization per TurboQuant (arXiv:2504.19874,
Zandieh et al.), appended after the fork's Q2_0=42:
  GGML_TYPE_TQ3_0 = 43  (14 B / 32 values = 3.5 bpw: fp16 RMS scale + 12 B of 3-bit codes)
  GGML_TYPE_TQ4_0 = 44  (18 B / 32 values = 4.5 bpw: fp16 RMS scale + 16 B of 4-bit codes)

Pipeline per 32-value block: RMS scale -> deterministic sign flips
(golden-ratio hash 0x9E3779B9) + 5-stage Walsh-Hadamard butterfly,
1/sqrt(32)-normalized -> nearest-centroid Lloyd-Max lookup. The paper's
QR-decomposed Gaussian rotation is replaced by this randomized Hadamard
transform (community-validated substitution; see suiban/docs/turboquant.md).

TQ3_0 port of the MIT-licensed Aaryan-Kapoor/llama.cpp branch
turboquant-tq3_0 (commit 1fb1fb3ab6b3e5c3776a362d7ac7f5985328d71b);
TQ4_0 is our extension of the same pattern. TQ4 codebook generated by
suiban/vendor/codebooks/generate.py, cross-checked against Max (1960).
Divergence from the reference: all-zero blocks store d = 0 so they
round-trip to exact zeros (the reference emitted scaled centroid noise).
---
diff --git a/ggml/include/ggml.h b/ggml/include/ggml.h
index 915ce0f..9a2cc2e 100644
--- a/ggml/include/ggml.h
+++ b/ggml/include/ggml.h
@@ -430,7 +430,9 @@ extern "C" {
         GGML_TYPE_NVFP4   = 40, // NVFP4 (4 blocks, E4M3 scale)
         GGML_TYPE_Q1_0    = 41,
         GGML_TYPE_Q2_0    = 42,
-        GGML_TYPE_COUNT   = 43,
+        GGML_TYPE_TQ3_0   = 43, // TurboQuant 3-bit (RHT rotation + Lloyd-Max codebook), KV-cache oriented
+        GGML_TYPE_TQ4_0   = 44, // TurboQuant 4-bit (RHT rotation + Lloyd-Max codebook), KV-cache oriented
+        GGML_TYPE_COUNT   = 45,
     };
 
     // precision
diff --git a/ggml/src/ggml-common.h b/ggml/src/ggml-common.h
index 3bccec1..3879a88 100644
--- a/ggml/src/ggml-common.h
+++ b/ggml/src/ggml-common.h
@@ -287,6 +287,24 @@ typedef struct {
 } block_tq2_0;
 static_assert(sizeof(block_tq2_0) == sizeof(ggml_half) + QK_K / 4, "wrong tq2_0 block size/padding");
 
+// TurboQuant 3-bit (3.5 bpw), KV-cache oriented (arXiv:2504.19874)
+// 32 values per block: RMS scale + randomized Hadamard transform + Lloyd-Max 8-level codebook
+#define QK_TQ3_0 32
+typedef struct {
+    ggml_half d;                   // scale factor (RMS of block)
+    uint8_t qs[QK_TQ3_0 * 3 / 8];  // 3-bit quant indices, packed (12 bytes)
+} block_tq3_0;
+static_assert(sizeof(block_tq3_0) == sizeof(ggml_half) + QK_TQ3_0 * 3 / 8, "wrong tq3_0 block size/padding");
+
+// TurboQuant 4-bit (4.5 bpw), KV-cache oriented (arXiv:2504.19874)
+// 32 values per block: RMS scale + randomized Hadamard transform + Lloyd-Max 16-level codebook
+#define QK_TQ4_0 32
+typedef struct {
+    ggml_half d;                   // scale factor (RMS of block)
+    uint8_t qs[QK_TQ4_0 / 2];      // 4-bit quant indices, packed (16 bytes)
+} block_tq4_0;
+static_assert(sizeof(block_tq4_0) == sizeof(ggml_half) + QK_TQ4_0 / 2, "wrong tq4_0 block size/padding");
+
 //
 // Super-block quantization structures
 //
diff --git a/ggml/src/ggml-quants.c b/ggml/src/ggml-quants.c
index 1ebc50a..7a33c7f 100644
--- a/ggml/src/ggml-quants.c
+++ b/ggml/src/ggml-quants.c
@@ -2425,6 +2425,257 @@ size_t quantize_tq2_0(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst,
     return nrow * row_size;
 }
 
+// ====================== TurboQuant TQ3_0 / TQ4_0 (arXiv:2504.19874) ======================
+//
+// KV-cache oriented block quantization, 32 values per block:
+//   RMS scale (fp16) -> deterministic sign flips + Walsh-Hadamard transform
+//   (randomized Hadamard transform) -> per-coordinate Lloyd-Max scalar
+//   quantization against an N(0,1) codebook.
+//
+// The paper's rotation is a QR-decomposed Gaussian matrix; the fast RHT here is
+// the community-validated substitution (see suiban/docs/turboquant.md).
+// TQ3_0 constants are ported from the MIT-licensed Aaryan-Kapoor/llama.cpp
+// branch `turboquant-tq3_0` (commit 1fb1fb3); TQ4_0 constants are generated by
+// suiban/vendor/codebooks/generate.py (Lloyd-Max on N(0,1), converged < 1e-12)
+// and cross-checked against Max (1960). Keep in sync with
+// suiban/vendor/codebooks/tq_codebooks.h.
+
+#define QK_TQ 32 // block size shared by TQ3_0 and TQ4_0 (== QK_TQ3_0 == QK_TQ4_0)
+
+// Lloyd-Max 8-level codebook centroids for N(0,1) (theoretical MSE 0.034548)
+static const float TQ3_0_CENTROIDS[8] = {
+    -2.1519f, -1.3439f, -0.7560f, -0.2451f,
+    +0.2451f, +0.7560f, +1.3439f, +2.1519f,
+};
+
+// Decision boundaries (midpoints between adjacent centroids)
+static const float TQ3_0_BOUNDARIES[7] = {
+    -1.7479f, -1.0500f, -0.5005f, +0.0000f,
+    +0.5005f, +1.0500f, +1.7479f,
+};
+
+// Lloyd-Max 16-level codebook centroids for N(0,1) (theoretical MSE 0.009501)
+static const float TQ4_0_CENTROIDS[16] = {
+    -2.7325896f, -2.0690172f, -1.6180464f, -1.2562312f,
+    -0.9423405f, -0.6567591f, -0.3880483f, -0.1283950f,
+    +0.1283950f, +0.3880483f, +0.6567591f, +0.9423405f,
+    +1.2562312f, +1.6180464f, +2.0690172f, +2.7325896f,
+};
+
+// Decision boundaries (midpoints between adjacent centroids)
+static const float TQ4_0_BOUNDARIES[15] = {
+    -2.4008034f, -1.8435318f, -1.4371388f, -1.0992859f,
+    -0.7995498f, -0.5224037f, -0.2582217f, +0.0000000f,
+    +0.2582217f, +0.5224037f, +0.7995498f, +1.0992859f,
+    +1.4371388f, +1.8435318f, +2.4008034f,
+};
+
+// Deterministic sign flip pattern for the randomized Hadamard transform
+// Generated from golden ratio hash: sign[i] = ((i * 0x9E3779B9) >> 31) ? -1.0 : +1.0
+static const float TQ_RHT_SIGNS[32] = {
+    +1.0f, -1.0f, +1.0f, -1.0f, +1.0f, +1.0f, -1.0f, +1.0f,
+    -1.0f, -1.0f, +1.0f, -1.0f, +1.0f, +1.0f, -1.0f, +1.0f,
+    -1.0f, -1.0f, +1.0f, -1.0f, +1.0f, -1.0f, -1.0f, +1.0f,
+    -1.0f, +1.0f, +1.0f, -1.0f, +1.0f, -1.0f, -1.0f, +1.0f,
+};
+
+// Forward randomized Hadamard transform: sign flips + WHT + 1/sqrt(32) normalization
+static void tq_rht_forward(const float * GGML_RESTRICT in, float * GGML_RESTRICT out) {
+    for (int i = 0; i < QK_TQ; i++) {
+        out[i] = in[i] * TQ_RHT_SIGNS[i];
+    }
+
+    // in-place WHT butterfly (5 stages for n=32)
+    for (int step = 1; step < QK_TQ; step <<= 1) {
+        for (int i = 0; i < QK_TQ; i += step << 1) {
+            for (int j = i; j < i + step; j++) {
+                const float a = out[j];
+                const float b = out[j + step];
+                out[j]        = a + b;
+                out[j + step] = a - b;
+            }
+        }
+    }
+
+    const float norm = 1.0f / sqrtf((float) QK_TQ);
+    for (int i = 0; i < QK_TQ; i++) {
+        out[i] *= norm;
+    }
+}
+
+// Inverse randomized Hadamard transform: WHT + 1/sqrt(32) normalization + undo sign flips
+// (the normalized WHT is involutive, so the butterfly is identical to the forward pass)
+static void tq_rht_inverse(const float * GGML_RESTRICT in, float * GGML_RESTRICT out) {
+    for (int i = 0; i < QK_TQ; i++) {
+        out[i] = in[i];
+    }
+
+    for (int step = 1; step < QK_TQ; step <<= 1) {
+        for (int i = 0; i < QK_TQ; i += step << 1) {
+            for (int j = i; j < i + step; j++) {
+                const float a = out[j];
+                const float b = out[j + step];
+                out[j]        = a + b;
+                out[j + step] = a - b;
+            }
+        }
+    }
+
+    const float norm = 1.0f / sqrtf((float) QK_TQ);
+    for (int i = 0; i < QK_TQ; i++) {
+        out[i] *= norm * TQ_RHT_SIGNS[i];
+    }
+}
+
+// Quantize one 32-block: RMS scale, RHT, nearest-centroid lookup.
+// nlevels is 8 (TQ3_0) or 16 (TQ4_0); indices[] receives QK_TQ codebook indices.
+static float tq_quantize_block(const float * GGML_RESTRICT x, uint8_t * GGML_RESTRICT indices,
+                               const float * boundaries, int nlevels) {
+    float sum_sq = 0.0f;
+    for (int j = 0; j < QK_TQ; j++) {
+        sum_sq += x[j] * x[j];
+    }
+    const float rms = sqrtf(sum_sq / QK_TQ);
+
+    if (rms < 1e-10f) {
+        // all-zero (or vanishing) block: store d = 0 so dequantization returns
+        // exact zeros instead of scaled centroid noise
+        memset(indices, 0, QK_TQ);
+        return 0.0f;
+    }
+
+    float normalized[QK_TQ];
+    const float inv_rms = 1.0f / rms;
+    for (int j = 0; j < QK_TQ; j++) {
+        normalized[j] = x[j] * inv_rms;
+    }
+
+    float rotated[QK_TQ];
+    tq_rht_forward(normalized, rotated);
+
+    for (int j = 0; j < QK_TQ; j++) {
+        const float v = rotated[j];
+        uint8_t idx = 0;
+        for (int b = 0; b < nlevels - 1; b++) {
+            if (v > boundaries[b]) {
+                idx = (uint8_t) (b + 1);
+            }
+        }
+        indices[j] = idx;
+    }
+
+    return rms;
+}
+
+// Dequantize one 32-block: centroid lookup, inverse RHT, rescale.
+static void tq_dequantize_block(const uint8_t * GGML_RESTRICT indices, float * GGML_RESTRICT y,
+                                const float * centroids, float d) {
+    float rotated[QK_TQ];
+    for (int j = 0; j < QK_TQ; j++) {
+        rotated[j] = centroids[indices[j]];
+    }
+
+    float dequantized[QK_TQ];
+    tq_rht_inverse(rotated, dequantized);
+
+    for (int j = 0; j < QK_TQ; j++) {
+        y[j] = dequantized[j] * d;
+    }
+}
+
+void quantize_row_tq3_0_ref(const float * GGML_RESTRICT x, block_tq3_0 * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ3_0 == 0);
+    const int64_t nb = k / QK_TQ3_0;
+
+    for (int64_t i = 0; i < nb; i++) {
+        uint8_t indices[QK_TQ3_0];
+        const float rms = tq_quantize_block(x + i*QK_TQ3_0, indices, TQ3_0_BOUNDARIES, 8);
+        y[i].d = GGML_FP32_TO_FP16(rms);
+
+        // pack 3-bit indices (groups of 8 indices -> 3 bytes)
+        for (int g = 0; g < 4; g++) {
+            const uint8_t * idx = indices + g * 8;
+            uint8_t * qp = y[i].qs + g * 3;
+            qp[0] = (uint8_t) ((idx[0])      | (idx[1] << 3) | (idx[2] << 6));
+            qp[1] = (uint8_t) ((idx[2] >> 2) | (idx[3] << 1) | (idx[4] << 4) | (idx[5] << 7));
+            qp[2] = (uint8_t) ((idx[5] >> 1) | (idx[6] << 2) | (idx[7] << 5));
+        }
+    }
+}
+
+void dequantize_row_tq3_0(const block_tq3_0 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ3_0 == 0);
+    const int64_t nb = k / QK_TQ3_0;
+
+    for (int64_t i = 0; i < nb; i++) {
+        const float d = GGML_FP16_TO_FP32(x[i].d);
+
+        // unpack 3-bit indices
+        uint8_t indices[QK_TQ3_0];
+        for (int g = 0; g < 4; g++) {
+            const uint8_t * qp = x[i].qs + g * 3;
+            uint8_t * idx = indices + g * 8;
+            idx[0] =  qp[0]       & 7;
+            idx[1] = (qp[0] >> 3) & 7;
+            idx[2] = (uint8_t) (((qp[0] >> 6) | (qp[1] << 2)) & 7);
+            idx[3] = (qp[1] >> 1) & 7;
+            idx[4] = (qp[1] >> 4) & 7;
+            idx[5] = (uint8_t) (((qp[1] >> 7) | (qp[2] << 1)) & 7);
+            idx[6] = (qp[2] >> 2) & 7;
+            idx[7] = (qp[2] >> 5) & 7;
+        }
+
+        tq_dequantize_block(indices, y + i*QK_TQ3_0, TQ3_0_CENTROIDS, d);
+    }
+}
+
+size_t quantize_tq3_0(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst, int64_t nrow, int64_t n_per_row, const float * quant_weights) {
+    (void)quant_weights; // not used - codebook is fixed
+    const size_t row_size = ggml_row_size(GGML_TYPE_TQ3_0, n_per_row);
+    quantize_row_tq3_0_ref(src, dst, (int64_t)nrow*n_per_row);
+    return nrow * row_size;
+}
+
+void quantize_row_tq4_0_ref(const float * GGML_RESTRICT x, block_tq4_0 * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ4_0 == 0);
+    const int64_t nb = k / QK_TQ4_0;
+
+    for (int64_t i = 0; i < nb; i++) {
+        uint8_t indices[QK_TQ4_0];
+        const float rms = tq_quantize_block(x + i*QK_TQ4_0, indices, TQ4_0_BOUNDARIES, 16);
+        y[i].d = GGML_FP32_TO_FP16(rms);
+
+        // pack 4-bit indices (2 per byte: even index in the low nibble)
+        for (int j = 0; j < QK_TQ4_0 / 2; j++) {
+            y[i].qs[j] = (uint8_t) (indices[2*j] | (indices[2*j + 1] << 4));
+        }
+    }
+}
+
+void dequantize_row_tq4_0(const block_tq4_0 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ4_0 == 0);
+    const int64_t nb = k / QK_TQ4_0;
+
+    for (int64_t i = 0; i < nb; i++) {
+        const float d = GGML_FP16_TO_FP32(x[i].d);
+
+        uint8_t indices[QK_TQ4_0];
+        for (int j = 0; j < QK_TQ4_0 / 2; j++) {
+            indices[2*j]     =  x[i].qs[j]       & 0xF;
+            indices[2*j + 1] = (x[i].qs[j] >> 4) & 0xF;
+        }
+
+        tq_dequantize_block(indices, y + i*QK_TQ4_0, TQ4_0_CENTROIDS, d);
+    }
+}
+
+size_t quantize_tq4_0(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst, int64_t nrow, int64_t n_per_row, const float * quant_weights) {
+    (void)quant_weights; // not used - codebook is fixed
+    const size_t row_size = ggml_row_size(GGML_TYPE_TQ4_0, n_per_row);
+    quantize_row_tq4_0_ref(src, dst, (int64_t)nrow*n_per_row);
+    return nrow * row_size;
+}
+
 void dequantize_row_tq1_0(const block_tq1_0 * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
     assert(k % QK_K == 0);
     const int64_t nb = k / QK_K;
@@ -5604,6 +5855,14 @@ bool ggml_validate_row_data(enum ggml_type type, const void * data, size_t nbyte
             {
                 VALIDATE_ROW_DATA_D_F16_IMPL(block_tq2_0, data, nb);
             } break;
+        case GGML_TYPE_TQ3_0:
+            {
+                VALIDATE_ROW_DATA_D_F16_IMPL(block_tq3_0, data, nb);
+            } break;
+        case GGML_TYPE_TQ4_0:
+            {
+                VALIDATE_ROW_DATA_D_F16_IMPL(block_tq4_0, data, nb);
+            } break;
         case GGML_TYPE_IQ1_S:
             {
                 VALIDATE_ROW_DATA_D_F16_IMPL(block_iq1_s, data, nb);
