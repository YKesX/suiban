     float vals[ne];
+    bool  done = false;
+
+#ifndef GGML_USE_HIP
+    if constexpr (ne == 4) {
+        if (__all_sync(0xFFFFFFFF, (int) (threadIdx.x % 8)*4 == j0)) {
+            float r[4];
+            float d;
+            if constexpr (type_V == GGML_TYPE_TQ3_0) {
+                const block_tq3_0 * x = (const block_tq3_0 *) vx;
+                const int64_t ib = i0 / QK_TQ3_0;
+                uint8_t qs[QK_TQ3_0*3/8];
+                ggml_cuda_memcpy_1<QK_TQ3_0*3/8, 2>(qs, x[ib].qs);
+#pragma unroll
+                for (int l = 0; l < 4; ++l) {
+                    r[l] = tq3_0_centroids[ggml_cuda_tq3_0_get_code(qs, j0 + l)];
+                }
+                d = __half2float(x[ib].d);
+            } else {
+                static_assert(type_V == GGML_TYPE_TQ3_0 || type_V == GGML_TYPE_TQ4_0, "bad type");
+                const block_tq4_0 * x = (const block_tq4_0 *) vx;
+                const int64_t ib = i0 / QK_TQ4_0;
+                uint8_t qs[QK_TQ4_0/2];
+                ggml_cuda_memcpy_1<QK_TQ4_0/2, 2>(qs, x[ib].qs);
 #pragma unroll
-    for (int l = 0; l < ne; ++l) {
-        vals[l] = ggml_cuda_tq_dequant_elem(c, j0 + l, dn);
+                for (int l = 0; l < 4; ++l) {
+                    r[l] = tq4_0_centroids[ggml_cuda_tq4_0_get_code(qs, j0 + l)];
+                }
+                d = __half2float(x[ib].d);
+            }
+
+            // WHT stages m = 1, 2 (j bits 0-1): both butterfly partners live
+            // in this lane's registers. Same pairwise order as the CPU
+            // reference butterfly: low element a+b, high element a-b.
+            {
+                float t0, t1;
+                t0 = r[0]; t1 = r[1]; r[0] = t0 + t1; r[1] = t0 - t1;
+                t0 = r[2]; t1 = r[3]; r[2] = t0 + t1; r[3] = t0 - t1;
+                t0 = r[0]; t1 = r[2]; r[0] = t0 + t1; r[2] = t0 - t1;
+                t0 = r[1]; t1 = r[3]; r[1] = t0 + t1; r[3] = t0 - t1;
+            }
+            // WHT stages m = 4, 8, 16 (j bits 2-4): the partner element sits
+            // in lane ^ (m/4) of the aligned 8-lane group.
+#pragma unroll
+            for (int lm = 1; lm <= 4; lm <<= 1) {
+#pragma unroll
+                for (int l = 0; l < 4; ++l) {
+                    const float other = __shfl_xor_sync(0xFFFFFFFF, r[l], lm, 8);
+                    r[l] = (threadIdx.x & lm) ? (other - r[l]) : (r[l] + other);
+                }
+            }
+
+            const float dn = d * TQ_RSQRT32;
+#pragma unroll
+            for (int l = 0; l < 4; ++l) {
+                vals[l] = r[l] * ggml_cuda_tq_sign(j0 + l) * dn;
+            }
+            done = true;
+        }
+    }
+#endif // GGML_USE_HIP
+
+    if (!done) {
+        float c[QK_TQ];
+        float d;
+        if constexpr (type_V == GGML_TYPE_TQ3_0) {
+            const block_tq3_0 * x = (const block_tq3_0 *) vx;
+            const int64_t ib = i0 / QK_TQ3_0;
+            ggml_cuda_tq3_0_block_centroids(&x[ib], c);
+            d = __half2float(x[ib].d);
+        } else {
+            static_assert(type_V == GGML_TYPE_TQ3_0 || type_V == GGML_TYPE_TQ4_0, "bad type");
+            const block_tq4_0 * x = (const block_tq4_0 *) vx;
+            const int64_t ib = i0 / QK_TQ4_0;
+            ggml_cuda_tq4_0_block_centroids(&x[ib], c);
+            d = __half2float(x[ib].d);
+        }
+
+        const float dn = d * TQ_RSQRT32;
+#pragma unroll
+        for (int l = 0; l < ne; ++l) {
+            vals[l] = ggml_cuda_tq_dequant_elem(c, j0 + l, dn);
+        }
     }
 
