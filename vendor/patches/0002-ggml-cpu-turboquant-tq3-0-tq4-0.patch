Subject: [PATCH 2/4] ggml-cpu: TQ3_0 / TQ4_0 wrappers, vec_dot, op case lists

CPU backend registration for the TurboQuant types: type_traits_cpu entries
(vec_dot_type = Q8_0), quantize_row wrappers, scalar reference vec_dot
(dequantize through the inverse RHT, then dot with q8_0 — no SIMD variants
in v1), and the quantized-type case lists in ops.cpp (add/add1/acc/out_prod/
set/get_rows/clamp). CPU flash-attention needs no extra wiring: it reads V
through ggml_get_type_traits(v->type)->to_float, and SET_ROWS/CPY use
from_float generically.
---
diff --git a/ggml/src/ggml-cpu/ggml-cpu.c b/ggml/src/ggml-cpu/ggml-cpu.c
index 67e88ef..291a604 100644
--- a/ggml/src/ggml-cpu/ggml-cpu.c
+++ b/ggml/src/ggml-cpu/ggml-cpu.c
@@ -410,6 +410,18 @@ static const struct ggml_type_traits_cpu type_traits_cpu[GGML_TYPE_COUNT] = {
         .vec_dot_type             = GGML_TYPE_Q8_K,
         .nrows                    = 1,
     },
+    [GGML_TYPE_TQ3_0] = {
+        .from_float               = quantize_row_tq3_0,
+        .vec_dot                  = ggml_vec_dot_tq3_0_q8_0,
+        .vec_dot_type             = GGML_TYPE_Q8_0,
+        .nrows                    = 1,
+    },
+    [GGML_TYPE_TQ4_0] = {
+        .from_float               = quantize_row_tq4_0,
+        .vec_dot                  = ggml_vec_dot_tq4_0_q8_0,
+        .vec_dot_type             = GGML_TYPE_Q8_0,
+        .nrows                    = 1,
+    },
     [GGML_TYPE_I32] = {
         .from_float               = (ggml_from_float_t) ggml_cpu_fp32_to_i32,
     },
