diff --git a/ggml/src/ggml-cuda/turboquant.cuh b/ggml/src/ggml-cuda/turboquant.cuh
new file mode 100644
--- /dev/null
+++ b/ggml/src/ggml-cuda/turboquant.cuh
@@ -0,0 +1,217 @@
+#pragma once
+
+// TurboQuant TQ3_0 / TQ4_0 (arXiv:2504.19874, Zandieh et al.) — CUDA device-side helpers.
+//
+// KV-cache oriented block quantization, 32 values per block:
+//   RMS scale (fp16) -> deterministic sign flips + Walsh-Hadamard transform
+//   (randomized Hadamard transform) -> per-coordinate Lloyd-Max scalar
+//   quantization against an N(0,1) codebook.
+//
+// Clean-room implementation: written against the CPU reference kernels in
+// ggml/src/ggml-quants.c (this patchset) and the existing ggml-cuda idioms for
+// quantized KV handling (cpy-utils.cuh, fattn-common.cuh). No code from the
+// unlicensed community CUDA gist is used.
+//
+// Codebook constants MUST stay in sync with ggml/src/ggml-quants.c and
+// suiban/vendor/codebooks/tq_codebooks.h (single source of truth: the
+// generator suiban/vendor/codebooks/generate.py).
+
+#include "common.cuh"
+
+#define QK_TQ 32 // block size shared by TQ3_0 and TQ4_0 (== QK_TQ3_0 == QK_TQ4_0)
+
+// 1/sqrt(32): normalization of the Walsh-Hadamard butterfly
+#define TQ_RSQRT32 0.17677669529663688f
+
+// Deterministic sign-flip pattern for the randomized Hadamard transform, as a
+// bitmask: bit j set -> sign[j] = -1. Identical to the CPU reference table
+// TQ_RHT_SIGNS (generated from the golden-ratio hash
+// sign[i] = ((i * 0x9E3779B9) >> 31) ? -1 : +1).
+#define TQ_RHT_SIGN_MASK 0x696B4B4Au
+
+static __device__ __forceinline__ float ggml_cuda_tq_sign(const int j) {
+    return (TQ_RHT_SIGN_MASK >> j) & 1u ? -1.0f : 1.0f;
+}
+
+// Lloyd-Max 8-level codebook centroids for N(0,1) (theoretical MSE 0.034548)
+static const __device__ float tq3_0_centroids[8] = {
+    -2.1519f, -1.3439f, -0.7560f, -0.2451f,
+    +0.2451f, +0.7560f, +1.3439f, +2.1519f,
+};
+
+// Decision boundaries (midpoints between adjacent centroids)
+static const __device__ float tq3_0_boundaries[7] = {
+    -1.7479f, -1.0500f, -0.5005f, +0.0000f,
+    +0.5005f, +1.0500f, +1.7479f,
+};
+
+// Lloyd-Max 16-level codebook centroids for N(0,1) (theoretical MSE 0.009501)
+static const __device__ float tq4_0_centroids[16] = {
+    -2.7325896f, -2.0690172f, -1.6180464f, -1.2562312f,
+    -0.9423405f, -0.6567591f, -0.3880483f, -0.1283950f,
+    +0.1283950f, +0.3880483f, +0.6567591f, +0.9423405f,
+    +1.2562312f, +1.6180464f, +2.0690172f, +2.7325896f,
+};
+
+// Decision boundaries (midpoints between adjacent centroids)
+static const __device__ float tq4_0_boundaries[15] = {
+    -2.4008034f, -1.8435318f, -1.4371388f, -1.0992859f,
+    -0.7995498f, -0.5224037f, -0.2582217f, +0.0000000f,
+    +0.2582217f, +0.5224037f, +0.7995498f, +1.0992859f,
+    +1.4371388f, +1.8435318f, +2.4008034f,
+};
+
+// In-place 5-stage Walsh-Hadamard butterfly (natural order), identical to the
+// CPU reference tq_rht_forward/tq_rht_inverse core. Involutive up to the
+// 1/sqrt(32) normalization, which callers apply themselves.
+static __device__ __forceinline__ void ggml_cuda_tq_wht32(float * v) {
+#pragma unroll
+    for (int step = 1; step < QK_TQ; step <<= 1) {
+#pragma unroll
+        for (int i = 0; i < QK_TQ; i += step << 1) {
+#pragma unroll
+            for (int j = i; j < i + step; j++) {
+                const float a = v[j];
+                const float b = v[j + step];
+                v[j]        = a + b;
+                v[j + step] = a - b;
+            }
+        }
+    }
+}
+
+// Extract the 3-bit code of element k (0..31) from a tq3_0 block's packed qs.
+// Bit layout identical to the CPU reference pack/unpack (groups of 8 indices
+// -> 3 bytes); 3-bit fields at bit offsets 6 and 7 within a byte straddle
+// into the next byte of the same 3-byte group, never out of bounds.
+static __device__ __forceinline__ int ggml_cuda_tq3_0_get_code(const uint8_t * qs, const int k) {
+    const uint8_t * qp  = qs + 3*(k >> 3);
+    const int       bit = 3*(k & 7);
+    int v = qp[bit >> 3] >> (bit & 7);
+    if ((bit & 7) > 5) {
+        v |= qp[(bit >> 3) + 1] << (8 - (bit & 7));
+    }
+    return v & 7;
+}
+
+// Extract the 4-bit code of element k (0..31) from a tq4_0 block's packed qs
+// (2 codes per byte, even index in the low nibble — same as the CPU reference).
+static __device__ __forceinline__ int ggml_cuda_tq4_0_get_code(const uint8_t * qs, const int k) {
+    return (qs[k >> 1] >> (4*(k & 1))) & 0xF;
+}
+
+// Quantize one 32-value block: RMS scale -> sign flips + WHT -> nearest
+// centroid (linear boundary scan, identical tie behavior to the CPU
+// reference). nlevels is 8 (TQ3_0) or 16 (TQ4_0).
+// Returns the RMS scale; indices[] receives QK_TQ codebook indices.
+static __device__ float ggml_cuda_tq_quantize_block(
+        const float * __restrict__ x, uint8_t * __restrict__ indices,
+        const float * boundaries, const int nlevels) {
+    float sum_sq = 0.0f;
+#pragma unroll
+    for (int j = 0; j < QK_TQ; j++) {
+        sum_sq += x[j]*x[j];
+    }
+    const float rms = sqrtf(sum_sq / QK_TQ);
+
+    if (rms < 1e-10f) {
+        // all-zero (or vanishing) block: d = 0 so dequantization returns exact
+        // zeros instead of scaled centroid noise (same as the CPU reference)
+#pragma unroll
+        for (int j = 0; j < QK_TQ; j++) {
+            indices[j] = 0;
+        }
+        return 0.0f;
+    }
+
+    float v[QK_TQ];
+    const float inv_rms = 1.0f / rms;
+#pragma unroll
+    for (int j = 0; j < QK_TQ; j++) {
+        v[j] = x[j] * inv_rms * ggml_cuda_tq_sign(j);
+    }
+
+    ggml_cuda_tq_wht32(v);
+
+#pragma unroll
+    for (int j = 0; j < QK_TQ; j++) {
+        const float r = v[j] * TQ_RSQRT32;
+        uint8_t idx = 0;
+        for (int b = 0; b < nlevels - 1; b++) {
+            if (r > boundaries[b]) {
+                idx = (uint8_t) (b + 1);
+            }
+        }
+        indices[j] = idx;
+    }
+
+    return rms;
+}
+
+// f32 -> tq3_0, one block per thread (set-rows KV-write idiom, cpy-utils style)
+static __device__ void quantize_f32_tq3_0_block(const float * __restrict__ x, block_tq3_0 * __restrict__ y) {
+    uint8_t indices[QK_TQ];
+    const float rms = ggml_cuda_tq_quantize_block(x, indices, tq3_0_boundaries, 8);
+    y->d = __float2half(rms);
+
+    // pack 3-bit indices (groups of 8 indices -> 3 bytes), same as CPU reference
+#pragma unroll
+    for (int g = 0; g < 4; g++) {
+        const uint8_t * idx = indices + g*8;
+        uint8_t * qp = y->qs + g*3;
+        qp[0] = (uint8_t) ((idx[0])      | (idx[1] << 3) | (idx[2] << 6));
+        qp[1] = (uint8_t) ((idx[2] >> 2) | (idx[3] << 1) | (idx[4] << 4) | (idx[5] << 7));
+        qp[2] = (uint8_t) ((idx[5] >> 1) | (idx[6] << 2) | (idx[7] << 5));
+    }
+}
+
+// f32 -> tq4_0, one block per thread (set-rows KV-write idiom, cpy-utils style)
+static __device__ void quantize_f32_tq4_0_block(const float * __restrict__ x, block_tq4_0 * __restrict__ y) {
+    uint8_t indices[QK_TQ];
+    const float rms = ggml_cuda_tq_quantize_block(x, indices, tq4_0_boundaries, 16);
+    y->d = __float2half(rms);
+
+    // pack 4-bit indices (2 per byte: even index in the low nibble)
+#pragma unroll
+    for (int j = 0; j < QK_TQ/2; j++) {
+        y->qs[j] = (uint8_t) (indices[2*j] | (indices[2*j + 1] << 4));
+    }
+}
+
+// Dequantize output element j (0..31) of a block given the 32 centroid values
+// of that block. Uses the closed form of the inverse RHT:
+//   y[j] = d * (1/sqrt(32)) * sign[j] * sum_k (-1)^popc(j&k) * c[k]
+// which is exactly the CPU reference's WHT butterfly + sign + rescale, computed
+// per element so that fattn's per-thread dequantize_V contract can be met.
+// dn must be d * TQ_RSQRT32.
+static __device__ __forceinline__ float ggml_cuda_tq_dequant_elem(
+        const float * __restrict__ c, const int j, const float dn) {
+    float sum = 0.0f;
+#pragma unroll
+    for (int k = 0; k < QK_TQ; k++) {
+        sum += (__popc(j & k) & 1) ? -c[k] : c[k];
+    }
+    return sum * ggml_cuda_tq_sign(j) * dn;
+}
+
+// Load a tq3_0 block's codes as centroid values c[0..31].
+static __device__ __forceinline__ void ggml_cuda_tq3_0_block_centroids(
+        const block_tq3_0 * __restrict__ b, float * __restrict__ c) {
+    uint8_t qs[QK_TQ3_0*3/8];
+    ggml_cuda_memcpy_1<QK_TQ3_0*3/8, 2>(qs, b->qs);
+#pragma unroll
+    for (int k = 0; k < QK_TQ; k++) {
