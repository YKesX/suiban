+// TurboQuant TQ3_0/TQ4_0 (see turboquant.cuh): one warp per 32-value block.
+// Lane j holds the centroid of code j; a 5-stage __shfl_xor_sync butterfly
+// computes the inverse randomized Hadamard transform across the warp, then
+// lane j writes output element j. Supports non-contiguous input via block
+// strides s01/s02/s03 (same contract as dequantize_block_cuda); the output is
+// always dense.
+template <typename dst_t, ggml_type type>
+static __global__ void dequantize_block_tq(const void * __restrict__ vx, dst_t * __restrict__ y,
+        const int64_t nblk0, const int64_t ne01, const int64_t ne02, const int64_t ne03,
+        const int64_t s01, const int64_t s02, const int64_t s03) {
+    const int64_t nblk_total = nblk0*ne01*ne02*ne03;
+    const int lane = threadIdx.x;
+
+    for (int64_t w = (int64_t) blockIdx.x*blockDim.y + threadIdx.y; w < nblk_total;
+         w += (int64_t) gridDim.x*blockDim.y) {
+        int64_t t = w;
+        const int64_t i00b = t % nblk0; t /= nblk0;
+        const int64_t i01  = t % ne01;  t /= ne01;
+        const int64_t i02  = t % ne02;
+        const int64_t i03  = t / ne02;
+
+        const int64_t ib = i03*s03 + i02*s02 + i01*s01 + i00b;
+
+        float v;
+        float d;
+        if constexpr (type == GGML_TYPE_TQ3_0) {
+            const block_tq3_0 * x = (const block_tq3_0 *) vx + ib;
+            v = tq3_0_centroids[ggml_cuda_tq3_0_get_code(x->qs, lane)];
+            d = __half2float(x->d);
+        } else {
+            static_assert(type == GGML_TYPE_TQ3_0 || type == GGML_TYPE_TQ4_0, "bad type");
+            const block_tq4_0 * x = (const block_tq4_0 *) vx + ib;
+            v = tq4_0_centroids[ggml_cuda_tq4_0_get_code(x->qs, lane)];
+            d = __half2float(x->d);
+        }
+
+        // warp-parallel Walsh-Hadamard butterfly (natural order), equivalent to
+        // the CPU reference's sequential butterfly
+#pragma unroll
+        for (int m = 1; m < QK_TQ; m <<= 1) {
+            const float other = __shfl_xor_sync(0xFFFFFFFF, v, m, QK_TQ);
+            v = (lane & m) ? (other - v) : (v + other);
+        }
+        v *= TQ_RSQRT32 * ggml_cuda_tq_sign(lane) * d;
+
+        const int64_t iy = (((i03*ne02 + i02)*ne01 + i01)*nblk0 + i00b)*QK_TQ + lane;
+        y[iy] = ggml_cuda_cast<dst_t>(v);
+    }
+}
+
+template <typename dst_t, ggml_type type>
+static void dequantize_tq_cuda(const void * vx, dst_t * y,
+        const int64_t ne00, const int64_t ne01, const int64_t ne02, const int64_t ne03,
+        const int64_t s01, const int64_t s02, const int64_t s03, cudaStream_t stream) {
+    GGML_ASSERT(ne00 % QK_TQ == 0);
+    const int64_t nblk0      = ne00 / QK_TQ;
+    const int64_t nblk_total = nblk0*ne01*ne02*ne03;
+    constexpr int warps_per_cta = 4;
+    const dim3 block_dims(QK_TQ, warps_per_cta, 1);
+    const int64_t n_cta = (nblk_total + warps_per_cta - 1) / warps_per_cta;
+    const dim3 num_blocks((unsigned int) std::min<int64_t>(n_cta, 1 << 20), 1, 1);
+    dequantize_block_tq<dst_t, type><<<num_blocks, block_dims, 0, stream>>>
+        (vx, y, nblk0, ne01, ne02, ne03, s01, s02, s03);
+}
+
+template <typename dst_t>
+static void dequantize_row_tq3_0_cuda(const void * vx, dst_t * y, const int64_t k, cudaStream_t stream) {
+    dequantize_tq_cuda<dst_t, GGML_TYPE_TQ3_0>(vx, y, k, 1, 1, 1, k/QK_TQ, k/QK_TQ, k/QK_TQ, stream);
+}
+
+template <typename dst_t>
+static void dequantize_row_tq4_0_cuda(const void * vx, dst_t * y, const int64_t k, cudaStream_t stream) {
+    dequantize_tq_cuda<dst_t, GGML_TYPE_TQ4_0>(vx, y, k, 1, 1, 1, k/QK_TQ, k/QK_TQ, k/QK_TQ, stream);
+}
+
 template <typename src_t, typename dst_t>
 static __global__ void convert_unary(
         const void * __restrict__ vx, dst_t * __restrict__ y, const int64_t ne00, const int64_t ne01,
@@ -760,6 +836,10 @@ to_fp16_cuda_t ggml_get_to_fp16_cuda(ggml_type type) {
             return dequantize_row_mxfp4_cuda;
         case GGML_TYPE_NVFP4:
             return dequantize_row_nvfp4_cuda;
+        case GGML_TYPE_TQ3_0:
+            return dequantize_row_tq3_0_cuda;
+        case GGML_TYPE_TQ4_0:
+            return dequantize_row_tq4_0_cuda;
         case GGML_TYPE_F32:
