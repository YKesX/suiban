     GGML_ABORT("fatal error");
 }
 
@@ -421,11 +430,23 @@ static best_fattn_kernel ggml_cuda_get_best_fattn_kernel(const int device, const
             return BEST_FATTN_KERNEL_NONE;
     }
 
+    if (V->type == GGML_TYPE_TQ3_0 || V->type == GGML_TYPE_TQ4_0) {
+        // TurboQuant V cache: the mixed pair K = F16/Q8_0 with V = TQ3_0/TQ4_0
