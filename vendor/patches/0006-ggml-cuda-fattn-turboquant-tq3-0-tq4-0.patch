+// TurboQuant TQ3_0/TQ4_0 V cache (see turboquant.cuh). Unlike the per-element
+// formats above, TurboQuant dequantization needs the whole 32-value block (the
+// inverse randomized Hadamard transform mixes every coordinate into every
+// output), so each thread decodes the full block it lands in and evaluates its
+// ne outputs via the closed-form parity sum. The vec kernel always calls with
+// ne == 4 and i0 % 4 == 0, so a group never straddles a block boundary
+// (4 | 32). Reference implementation, correctness first.
+// TODO(v1.1): warp-cooperative shfl-butterfly fast path (the vec kernel's 32
+// V-threads of a warp read consecutive i0 of the same row) if profiling of the
+// decode-bound long-context case shows it matters.
+template <typename T, int ne, ggml_type type_V>
+static __device__ __forceinline__ void dequantize_V_tq(const void * __restrict__ vx, void * __restrict__ dst, const int64_t i0) {
+    static_assert(ne == 2 || ne == 4, "bad ne");
+
+    float c[QK_TQ];
+    float d;
+    if constexpr (type_V == GGML_TYPE_TQ3_0) {
+        const block_tq3_0 * x = (const block_tq3_0 *) vx;
+        const int64_t ib = i0 / QK_TQ3_0;
+        ggml_cuda_tq3_0_block_centroids(&x[ib], c);
+        d = __half2float(x[ib].d);
+    } else {
+        static_assert(type_V == GGML_TYPE_TQ3_0 || type_V == GGML_TYPE_TQ4_0, "bad type");
+        const block_tq4_0 * x = (const block_tq4_0 *) vx;
+        const int64_t ib = i0 / QK_TQ4_0;
+        ggml_cuda_tq4_0_block_centroids(&x[ib], c);
+        d = __half2float(x[ib].d);
+    }
+
+    const int   j0 = i0 % QK_TQ;
+    const float dn = d * TQ_RSQRT32;
+
+    float vals[ne];
+#pragma unroll
+    for (int l = 0; l < ne; ++l) {
+        vals[l] = ggml_cuda_tq_dequant_elem(c, j0 + l, dn);
+    }
+
+#ifdef FP16_AVAILABLE
+    if constexpr (std::is_same_v<T, half>) {
+#pragma unroll
+        for (int l0 = 0; l0 < ne; l0 += 2) {
+            ((half2 *) dst)[l0/2] = make_half2(vals[l0 + 0], vals[l0 + 1]);
+        }
+    } else
+#endif // FP16_AVAILABLE
+    if constexpr (std::is_same_v<T, float>) {
+#pragma unroll
+        for (int l = 0; l < ne; ++l) {
+            ((float *) dst)[l] = vals[l];
+        }
+    } else {
+        static_assert(std::is_same_v<T, void>, "bad type");
+    }
+}
+
+template <typename T, int ne>
+static __device__ __forceinline__ void dequantize_V_tq3_0(const void * __restrict__ vx, void * __restrict__ dst, const int64_t i0) {
+    dequantize_V_tq<T, ne, GGML_TYPE_TQ3_0>(vx, dst, i0);
+}
+
+template <typename T, int ne>
+static __device__ __forceinline__ void dequantize_V_tq4_0(const void * __restrict__ vx, void * __restrict__ dst, const int64_t i0) {
+    dequantize_V_tq<T, ne, GGML_TYPE_TQ4_0>(vx, dst, i0);
+}
+
 template <ggml_type type_K, int D, int nthreads>
 constexpr __device__ vec_dot_KQ_t get_vec_dot_KQ() {
     if constexpr (type_K == GGML_TYPE_F16) {
@@ -653,6 +720,10 @@ constexpr __device__ dequantize_V_t get_dequantize_V() {
         return dequantize_V_q5_1<T, ne>;
     } else if constexpr (type_V == GGML_TYPE_Q8_0) {
         return dequantize_V_q8_0<T, ne>;
+    } else if constexpr (type_V == GGML_TYPE_TQ3_0) {
+        return dequantize_V_tq3_0<T, ne>;
+    } else if constexpr (type_V == GGML_TYPE_TQ4_0) {
+        return dequantize_V_tq4_0<T, ne>;
     } else if constexpr (type_V == GGML_TYPE_BF16) {
         return dequantize_V_bf16<float, ne>;
     } else {
