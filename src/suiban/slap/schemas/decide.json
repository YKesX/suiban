{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slap.dev/schemas/decide.json",
  "title": "SLAP decide",
  "description": "Orchestrator's decision on task/artifacts after review + gates.",
  "type": "object",
  "properties": {
    "protocol": {
      "const": "SLAP"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "const": "decide"
    },
    "parent_task": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "accept",
        "reject",
        "retry",
        "escalate"
      ]
    },
    "accepted_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    }
  },
  "required": [
    "protocol",
    "version",
    "message_id",
    "task_id",
    "operation",
    "decision"
  ],
  "additionalProperties": false
}
