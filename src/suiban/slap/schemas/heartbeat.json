{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slap.dev/schemas/heartbeat.json",
  "title": "SLAP heartbeat",
  "description": "Liveness + coarse progress while a task runs.",
  "type": "object",
  "properties": {
    "protocol": {
      "const": "SLAP"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "const": "heartbeat"
    },
    "parent_task": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "note": {
      "type": "string"
    }
  },
  "required": [
    "protocol",
    "version",
    "message_id",
    "task_id",
    "operation"
  ],
  "additionalProperties": false
}
