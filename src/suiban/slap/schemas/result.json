{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slap.dev/schemas/result.json",
  "title": "SLAP result",
  "description": "Worker reports task outcome; every claim links to evidence.",
  "type": "object",
  "properties": {
    "protocol": {
      "const": "SLAP"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "const": "result"
    },
    "parent_task": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "failed"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        },
        "required": [
          "claim",
          "evidence"
        ],
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "protocol",
    "version",
    "message_id",
    "task_id",
    "operation",
    "status"
  ],
  "additionalProperties": false
}
