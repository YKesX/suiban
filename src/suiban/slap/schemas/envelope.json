{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slap.dev/schemas/envelope.json",
  "title": "SLAP message envelope",
  "description": "Fields shared by every SLAP message. Operation schemas extend this.",
  "type": "object",
  "properties": {
    "protocol": {
      "const": "SLAP"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "enum": [
        "assign",
        "result",
        "review",
        "decide",
        "error",
        "cancel",
        "heartbeat",
        "capability",
        "status"
      ]
    },
    "parent_task": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  },
  "required": [
    "protocol",
    "version",
    "message_id",
    "task_id",
    "operation"
  ]
}
